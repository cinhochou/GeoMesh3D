{
  "name": "3d-editor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "collab-server": "node scripts/y-websocket-server.mjs",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "generate-api:user": "openapi-typescript http://localhost:8081/v3/api-docs -o src/types/api-service-user.ts",
    "generate-api:auth": "openapi-typescript http://localhost:8082/v3/api-docs -o src/types/api-service-auth.ts",
    "generate-api": "run-p generate-api:user generate-api:auth",
    "dev:with-api": "npm run generate-api && vite"
  },
  "dependencies": {
    "lib0": "^0.2.117",
    "three": "^0.182.0",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3",
    "ws": "^8.20.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.10.1",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "~10.5.1",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.10.1",
    "prettier": "3.6.2",
    "typescript": "~5.9.0",
    "vite": "^7.2.4",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.1.5"
  }
}
